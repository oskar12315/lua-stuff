    BroomHack Cosmetic Changer UI Library — v2
    
    Layout matches the reference screenshot:
    ┌─────────────────────────────────────────────────────┐
    │ Cosmetic Changer                        [RightShift]│
    ├───────────────────┬─────────────────────────────────┤
    │ weapon filter     │ cosmetic filter                 │
    │ [search........]  │ [search............]            │
    │                   │ [skin] [wrap] [charm]           │
    │  ┌──┐ ┌──┐ ┌──┐  │  ┌──┐ ┌──┐ ┌──┐               │
    │  │  │ │  │ │  │  │  │  │ │  │ │  │               │
    │  └──┘ └──┘ └──┘  │  └──┘ └──┘ └──┘               │
    │  ...              │  ...                            │
    │                   │                                 │
    │                   │ [  apply selected to all  ]     │
    │                   │ right click weapon to remove    │
    └───────────────────┴─────────────────────────────────┘
    
    Usage:
        local UI = require(...)
        local changer = UI.new()
        
        changer:AddWeapon({
            Name = "Assault Rifle",
            Model = someModel,          -- or Image = "rbxassetid://..."
            Skins = {
                { Name = "AK-47", Model = ..., Callback = function(w,s) end },
            },
            Wraps = {
                { Name = "Gold", Model = ... },
                "Diamond",  -- plain string also works
            },
            Charms = {
                { Name = "Star", Model = ... },
            },
            WrapCallback  = function(weaponName, wrapName) end,
            CharmCallback = function(weaponName, charmName) end,
        })
        
        changer:SetKeybind(Enum.KeyCode.RightShift)
]]

