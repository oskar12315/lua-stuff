-- ============================================
-- HELPERS
-- ============================================
local function create(className, props)
    local inst = Instance.new(className)
    for k, v in pairs(props) do
        if k ~= "Parent" then inst[k] = v end
    end
    if props.Parent then inst.Parent = props.Parent end
    return inst
end

local function makeDraggable(frame, handle)
    local dragging, dragStart, startPos
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging  = true
            dragStart = input.Position
            startPos  = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local d = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + d.X,
                startPos.Y.Scale, startPos.Y.Offset + d.Y
            )
        end
    end)
end

-- ============================================
-- BOUNDING BOX FOR VIEWPORT
-- ============================================
local function getModelBounds(model)
    local minV = Vector3.new(math.huge, math.huge, math.huge)
    local maxV = Vector3.new(-math.huge, -math.huge, -math.huge)
    local parts = {}
    if model:IsA("BasePart") then table.insert(parts, model) end
    for _, d in ipairs(model:GetDescendants()) do
        if d:IsA("BasePart") then table.insert(parts, d) end
    end
    if #parts == 0 then return Vector3.zero, Vector3.zero end
    for _, part in ipairs(parts) do
        local cf, sz = part.CFrame, part.Size
        for _, o in ipairs({
            Vector3.new(-1,-1,-1), Vector3.new(-1,-1,1), Vector3.new(-1,1,-1), Vector3.new(-1,1,1),
            Vector3.new(1,-1,-1),  Vector3.new(1,-1,1),  Vector3.new(1,1,-1),  Vector3.new(1,1,1),
        }) do
            local c = cf:PointToWorldSpace(sz * 0.5 * o)
            minV = Vector3.new(math.min(minV.X,c.X), math.min(minV.Y,c.Y), math.min(minV.Z,c.Z))
            maxV = Vector3.new(math.max(maxV.X,c.X), math.max(maxV.Y,c.Y), math.max(maxV.Z,c.Z))
        end
    end
    return (minV + maxV) * 0.5, maxV - minV
end

-- ============================================
-- VIEWPORT CREATION
-- ============================================
local function createViewport(parent, model, size, position)
    local vp = create("ViewportFrame", {
        Size = size, Position = position,
        BackgroundColor3 = Theme.ViewportBG,
        BackgroundTransparency = 0.3,
        BorderSizePixel = 0, Parent = parent,
    })
    create("UICorner", { CornerRadius = UDim.new(0,3), Parent = vp })
    vp.Ambient    = Color3.fromRGB(160, 155, 180)
    vp.LightColor = Color3.fromRGB(255, 255, 255)
    vp.LightDirection = Vector3.new(-1, -1, -1).Unit

    local clone = model:Clone()
    clone.Parent = vp
    if clone:IsA("BasePart") then clone.Anchored = true end
    for _, d in ipairs(clone:GetDescendants()) do
        if d:IsA("BasePart") then d.Anchored = true end
    end

    local center, extents = getModelBounds(clone)
    local maxE = math.max(extents.X, extents.Y, extents.Z, 0.1)
    local dist = (maxE * 0.5) / math.tan(math.rad(CAMERA_FOV) * 0.5) * 1.3

    local cam = Instance.new("Camera")
    cam.FieldOfView = CAMERA_FOV
    cam.CFrame = CFrame.new(center + Vector3.new(0, maxE * 0.15, dist), center)
    cam.Parent = vp
    vp.CurrentCamera = cam

    return vp, clone, cam, center, dist
end

-- ============================================
-- CONSTRUCTOR
-- ============================================
function BroomHackUI.new()
    local self = setmetatable({}, BroomHackUI)
    self.weapons         = {}
    self._weaponsByName  = {}
    self.selectedWeapon  = nil
    self.activeTab       = "skin"      -- "skin" | "wrap" | "charm"
    self.equippedSkins   = {}
    self.equippedWraps   = {}
    self.equippedCharms  = {}
    self._activeViewports = {}
    self._spinConnection  = nil
    self._weaponCells     = {}
    self._cosmeticCells   = {}
    self._weaponSearch    = ""
    self._cosmeticSearch  = ""
    self:_buildUI()
    self:_startSpinLoop()
    return self
end

-- ============================================
-- SPIN LOOP
-- ============================================
function BroomHackUI:_startSpinLoop()
    if self._spinConnection then return end
    self._spinConnection = RunService.RenderStepped:Connect(function(dt)
        for _, vp in ipairs(self._activeViewports) do
            vp.angle = vp.angle + ROTATE_SPEED * dt
            local rad = math.rad(vp.angle)
            local offset = Vector3.new(
                math.sin(rad) * vp.distance,
                vp.distance * 0.2,
                math.cos(rad) * vp.distance
            )
            vp.camera.CFrame = CFrame.new(vp.center + offset, vp.center)
        end
    end)
end

function BroomHackUI:_clearViewports()
    self._activeViewports = {}
end

function BroomHackUI:_registerViewport(camera, center, distance)
    table.insert(self._activeViewports, {
        camera = camera, center = center, distance = distance, angle = 0,
    })
end

-- ============================================
-- CREATE PREVIEW (3D or 2D or placeholder)
-- ============================================
function BroomHackUI:_createPreview(parent, data, imgSize, pos)
    if data.Model then
        local vp, _, cam, center, dist = createViewport(parent, data.Model,
            UDim2.new(0, imgSize, 0, imgSize), pos)
        self:_registerViewport(cam, center, dist)
        return vp
    elseif data.Image and data.Image ~= "" then
        return create("ImageLabel", {
            Size = UDim2.new(0, imgSize, 0, imgSize), Position = pos,
            BackgroundTransparency = 1, Image = data.Image,
            ScaleType = Enum.ScaleType.Fit, Parent = parent,
        })
    else
        local ph = create("Frame", {
            Size = UDim2.new(0, imgSize, 0, imgSize), Position = pos,
            BackgroundColor3 = Theme.ViewportBG, BorderSizePixel = 0, Parent = parent,
        })
        create("UICorner", { CornerRadius = UDim.new(0,3), Parent = ph })
        create("TextLabel", {
            Size = UDim2.new(1,0,1,0), BackgroundTransparency = 1,
            Text = "?", TextColor3 = Theme.SubText, TextSize = 20,
            Font = Enum.Font.GothamBold, Parent = ph,
        })
        return ph
    end
end

