        Size = UDim2.new(1,0,0,30),
        Position = UDim2.new(0,0,0.4,0),
        BackgroundTransparency = 1,
        Text = "select a weapon on the left",
        TextColor3 = Theme.SubText, TextSize = 12, Font = Enum.Font.Code,
        Visible = true, Parent = self.rightPanel,
    })

    -- ── RIGHT-CLICK on weapon = remove skin ──
    UserInputService.InputBegan:Connect(function(input, processed)
        if input.UserInputType == Enum.UserInputType.MouseButton2 then
            -- Check if over left panel
            local mousePos = UserInputService:GetMouseLocation()
            local lpAbs = self.leftPanel.AbsolutePosition
            local lpSz  = self.leftPanel.AbsoluteSize
            if self.mainFrame.Visible
                and mousePos.X >= lpAbs.X and mousePos.X <= lpAbs.X + lpSz.X
                and mousePos.Y >= lpAbs.Y and mousePos.Y <= lpAbs.Y + lpSz.Y then
                -- Find which weapon cell was right-clicked
                for _, wData in ipairs(self.weapons) do
                    if wData._cell then
                        local cAbs = wData._cell.AbsolutePosition
                        local cSz  = wData._cell.AbsoluteSize
                        if mousePos.X >= cAbs.X and mousePos.X <= cAbs.X + cSz.X
                            and mousePos.Y >= cAbs.Y and mousePos.Y <= cAbs.Y + cSz.Y then
                            -- Remove equipped cosmetic based on active tab
                            if self.activeTab == "skin" then
                                self.equippedSkins[wData.Name] = nil
                                if wData._skinDot then wData._skinDot.Visible = false end
                                -- Fire callback with nil
                                for _, sk in ipairs(wData.Skins or {}) do
                                    if sk.Callback then
                                        pcall(function() sk.Callback(wData.Name, nil) end)
                                        break
                                    end
                                end
                            elseif self.activeTab == "wrap" then
                                self.equippedWraps[wData.Name] = nil
                                if wData._wrapDot then wData._wrapDot.Visible = false end
                                if wData.WrapCallback then
                                    pcall(function() wData.WrapCallback(wData.Name, nil) end)
                                end
                            elseif self.activeTab == "charm" then
                                self.equippedCharms[wData.Name] = nil
                                if wData._charmDot then wData._charmDot.Visible = false end
                                if wData.CharmCallback then
                                    pcall(function() wData.CharmCallback(wData.Name, nil) end)
                                end
                            end
                            self:_refreshWeaponCell(wData)
                            if self.selectedWeapon == wData then
                                self:_renderCosmetics()
                            end
                            break
                        end
                    end
                end
            end
        end
    end)
end

-- ============================================
-- TAB SWITCHING
-- ============================================
function BroomHackUI:_switchTab(tabName)
    self.activeTab = tabName
    for name, btn in pairs(self._tabButtons) do
        if name == tabName then
            TweenService:Create(btn, TweenInfo.new(0.15), {
                BackgroundColor3 = Theme.TabActive, TextColor3 = Theme.TabTextActive
            }):Play()
        else
            TweenService:Create(btn, TweenInfo.new(0.15), {
                BackgroundColor3 = Theme.TabInactive, TextColor3 = Theme.TabTextInactive
            }):Play()
        end
    end
    self:_renderCosmetics()
end

-- ============================================
-- ADD WEAPON (public API)
-- ============================================
function BroomHackUI:AddWeapon(cfg)
    -- Normalize wraps
    local normalizedWraps = {}
    for _, w in ipairs(cfg.Wraps or {}) do
        if type(w) == "string" then
            table.insert(normalizedWraps, { Name = w })
        else
            table.insert(normalizedWraps, w)
        end
    end
    -- Normalize charms
    local normalizedCharms = {}
    for _, c in ipairs(cfg.Charms or {}) do
        if type(c) == "string" then
            table.insert(normalizedCharms, { Name = c })
        else
            table.insert(normalizedCharms, c)
        end
    end

    local weapon = {
        Name         = cfg.Name or "Unknown",
        Image        = cfg.Image or "",
        Model        = cfg.Model or nil,
        LayoutOrder  = cfg.LayoutOrder or (#self.weapons + 1),
        Skins        = cfg.Skins or {},
        Wraps        = normalizedWraps,
        Charms       = normalizedCharms,
        WrapCallback = cfg.WrapCallback,
        CharmCallback= cfg.CharmCallback,
        _cell        = nil,
        _skinDot     = nil,
        _wrapDot     = nil,
        _charmDot    = nil,
    }
    table.insert(self.weapons, weapon)
    self._weaponsByName[weapon.Name] = weapon
    self:_createWeaponCell(weapon)
end

-- ============================================
-- WEAPON CELL (left panel)
-- ============================================
function BroomHackUI:_createWeaponCell(weapon)
    local isSelected = (self.selectedWeapon == weapon)

    local cell = create("Frame", {
        Name = "W_" .. weapon.Name,
        BackgroundColor3 = isSelected and Theme.CellSelected or Theme.CellBg,
        BorderSizePixel = 0, LayoutOrder = weapon.LayoutOrder,
        Parent = self.weaponScroll,
    })
    create("UICorner", { CornerRadius = UDim.new(0,3), Parent = cell })
    local stroke = create("UIStroke", {
        Color = isSelected and Theme.Accent or Theme.Stroke,
        Thickness = 1, Transparency = isSelected and 0.2 or 0.6,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border, Parent = cell,
    })

    -- Preview
    self:_createPreview(cell, { Model = weapon.Model, Image = weapon.Image },
        IMG_SIZE_SMALL, UDim2.new(0.5, -IMG_SIZE_SMALL/2, 0, 3))

    -- Name label
    create("TextLabel", {
        Size = UDim2.new(1,-4,0,LABEL_H),
        Position = UDim2.new(0,2,1,-LABEL_H-1),
        BackgroundTransparency = 1, Text = weapon.Name,
        TextColor3 = isSelected and Theme.Accent or Theme.LabelText,
        TextSize = 9, Font = Enum.Font.Code,
        TextXAlignment = Enum.TextXAlignment.Center,
        TextTruncate = Enum.TextTruncate.AtEnd,
        Parent = cell,
    })

    -- Equipped dots
    local skinDot = create("Frame", {
        Size = UDim2.new(0,5,0,5), Position = UDim2.new(1,-8,0,3),
        BackgroundColor3 = Theme.Accent,
        Visible = self.equippedSkins[weapon.Name] ~= nil, Parent = cell,
    })
    create("UICorner", { CornerRadius = UDim.new(1,0), Parent = skinDot })

    local wrapDot = create("Frame", {
        Size = UDim2.new(0,5,0,5), Position = UDim2.new(1,-8,0,11),
        BackgroundColor3 = Color3.fromRGB(230, 180, 80),
        Visible = self.equippedWraps[weapon.Name] ~= nil, Parent = cell,
    })
    create("UICorner", { CornerRadius = UDim.new(1,0), Parent = wrapDot })

    local charmDot = create("Frame", {
        Size = UDim2.new(0,5,0,5), Position = UDim2.new(1,-8,0,19),
        BackgroundColor3 = Color3.fromRGB(80, 200, 80),
        Visible = self.equippedCharms[weapon.Name] ~= nil, Parent = cell,
    })
    create("UICorner", { CornerRadius = UDim.new(1,0), Parent = charmDot })

    weapon._cell     = cell
    weapon._skinDot  = skinDot
    weapon._wrapDot  = wrapDot
    weapon._charmDot = charmDot
    weapon._stroke   = stroke

    -- Click handler
    local btn = create("TextButton", {
        Size = UDim2.new(1,0,1,0), BackgroundTransparency = 1, Text = "",
        Parent = cell,
    })
    btn.MouseEnter:Connect(function()
        if self.selectedWeapon ~= weapon then
            TweenService:Create(cell, TweenInfo.new(0.12), { BackgroundColor3 = Theme.CellHover }):Play()
        end
    end)
    btn.MouseLeave:Connect(function()
        if self.selectedWeapon ~= weapon then
            TweenService:Create(cell, TweenInfo.new(0.12), { BackgroundColor3 = Theme.CellBg }):Play()
        end
    end)
    btn.MouseButton1Click:Connect(function()
        self:_selectWeapon(weapon)
    end)
end

-- ============================================
-- REFRESH WEAPON CELL (update dots/selection)
-- ============================================
function BroomHackUI:_refreshWeaponCell(weapon)
    if not weapon._cell then return end
    local isSelected = (self.selectedWeapon == weapon)
    weapon._cell.BackgroundColor3 = isSelected and Theme.CellSelected or Theme.CellBg
    if weapon._stroke then
        weapon._stroke.Color = isSelected and Theme.Accent or Theme.Stroke
        weapon._stroke.Transparency = isSelected and 0.2 or 0.6
    end
    -- Update label color
    for _, child in ipairs(weapon._cell:GetChildren()) do
        if child:IsA("TextLabel") then
            child.TextColor3 = isSelected and Theme.Accent or Theme.LabelText
        end
    end
    if weapon._skinDot then
        weapon._skinDot.Visible = self.equippedSkins[weapon.Name] ~= nil
    end
    if weapon._wrapDot then
        weapon._wrapDot.Visible = self.equippedWraps[weapon.Name] ~= nil
    end
    if weapon._charmDot then
        weapon._charmDot.Visible = self.equippedCharms[weapon.Name] ~= nil
    end
end

-- ============================================
-- SELECT WEAPON
-- ============================================
function BroomHackUI:_selectWeapon(weapon)
    local prev = self.selectedWeapon
    self.selectedWeapon = weapon

    if prev then self:_refreshWeaponCell(prev) end
    self:_refreshWeaponCell(weapon)

    self.noWeaponLabel.Visible = false
    self:_renderCosmetics()
end

-- ============================================
-- FILTER WEAPONS (search)
-- ============================================
function BroomHackUI:_filterWeapons()
    local q = self._weaponSearch
    for _, w in ipairs(self.weapons) do
        if w._cell then
            if q == "" or w.Name:lower():find(q, 1, true) then
                w._cell.Visible = true
            else
                w._cell.Visible = false
            end
        end
    end
end

-- ============================================
-- FILTER COSMETICS (search)
-- ============================================
function BroomHackUI:_filterCosmetics()
    local q = self._cosmeticSearch
    for _, entry in ipairs(self._cosmeticCells) do
        if entry.cell then
            if q == "" or entry.name:lower():find(q, 1, true) then
                entry.cell.Visible = true
            else
                entry.cell.Visible = false
            end
        end
    end
end

-- ============================================
-- RENDER COSMETICS (right panel grid)
-- ============================================
function BroomHackUI:_renderCosmetics()
    -- Clear existing
    self:_clearViewports()
    self._cosmeticCells = {}
    for _, c in ipairs(self.cosmeticScroll:GetChildren()) do
        if c:IsA("Frame") then c:Destroy() end
    end
    self.cosmeticScroll.CanvasPosition = Vector2.new(0, 0)

    local weapon = self.selectedWeapon
    if not weapon then
        self.noWeaponLabel.Visible = true
        return
    end
    self.noWeaponLabel.Visible = false

    local items = {}
    local equippedMap, equipCallback

    if self.activeTab == "skin" then
        items = weapon.Skins or {}
        equippedMap = self.equippedSkins
    elseif self.activeTab == "wrap" then
        items = weapon.Wraps or {}
        equippedMap = self.equippedWraps
    elseif self.activeTab == "charm" then
        items = weapon.Charms or {}
        equippedMap = self.equippedCharms
    end

    for i, item in ipairs(items) do
        local itemName = item.Name or item
        local isEq = (equippedMap[weapon.Name] == itemName)

        local cell = create("Frame", {
            Name = "C_" .. itemName,
            BackgroundColor3 = isEq and Theme.CellEquipped or Theme.CellBg,
            BorderSizePixel = 0, LayoutOrder = i,
            Parent = self.cosmeticScroll,
        })
        create("UICorner", { CornerRadius = UDim.new(0,3), Parent = cell })
        local stroke = create("UIStroke", {
            Color = isEq and Theme.EquipDot or Theme.Stroke,
            Thickness = 1, Transparency = isEq and 0.2 or 0.6,
            ApplyStrokeMode = Enum.ApplyStrokeMode.Border, Parent = cell,
        })

        -- Preview
        self:_createPreview(cell, { Model = item.Model, Image = item.Image },
            IMG_SIZE_BIG, UDim2.new(0.5, -IMG_SIZE_BIG/2, 0, 3))

        -- Label
        create("TextLabel", {
            Size = UDim2.new(1,-4,0,LABEL_H),
            Position = UDim2.new(0,2,1,-LABEL_H-1),
            BackgroundTransparency = 1, Text = itemName,
            TextColor3 = isEq and Theme.EquipDot or Theme.LabelText,
            TextSize = 10, Font = Enum.Font.Code,
            TextXAlignment = Enum.TextXAlignment.Center,
            TextTruncate = Enum.TextTruncate.AtEnd,
            Parent = cell,
        })

        if isEq then
            create("TextLabel", {
                Size = UDim2.new(0,14,0,14), Position = UDim2.new(1,-16,0,2),
                BackgroundTransparency = 1, Text = "✓",
                TextColor3 = Theme.EquipDot, TextSize = 12,
                Font = Enum.Font.GothamBold, Parent = cell,
            })
        end

        table.insert(self._cosmeticCells, { cell = cell, name = itemName })

        -- Click
        local btn = create("TextButton", {
            Size = UDim2.new(1,0,1,0), BackgroundTransparency = 1, Text = "",
            Parent = cell,
        })
        btn.MouseEnter:Connect(function()
            if equippedMap[weapon.Name] ~= itemName then
                TweenService:Create(cell, TweenInfo.new(0.12), { BackgroundColor3 = Theme.CellHover }):Play()
                TweenService:Create(stroke, TweenInfo.new(0.12), { Transparency = 0.3 }):Play()
            end
        end)
        btn.MouseLeave:Connect(function()
            if equippedMap[weapon.Name] ~= itemName then
                TweenService:Create(cell, TweenInfo.new(0.12), { BackgroundColor3 = Theme.CellBg }):Play()
                TweenService:Create(stroke, TweenInfo.new(0.12), { Transparency = 0.6 }):Play()
            end
        end)

        btn.MouseButton1Click:Connect(function()
            self:_equipCosmetic(weapon, itemName, item)
        end)
    end

    -- Apply search filter
    if self._cosmeticSearch ~= "" then
        self:_filterCosmetics()
    end
end

-- ============================================
-- EQUIP COSMETIC
-- ============================================
function BroomHackUI:_equipCosmetic(weapon, itemName, item)
    if self.activeTab == "skin" then
        self.equippedSkins[weapon.Name] = itemName
        if weapon._skinDot then weapon._skinDot.Visible = true end
        if item.Callback then
            pcall(function() item.Callback(weapon.Name, itemName) end)
        end

    elseif self.activeTab == "wrap" then
        self.equippedWraps[weapon.Name] = itemName
        if weapon._wrapDot then weapon._wrapDot.Visible = true end
        if weapon.WrapCallback then
            pcall(function() weapon.WrapCallback(weapon.Name, itemName) end)
        end

    elseif self.activeTab == "charm" then
        self.equippedCharms[weapon.Name] = itemName
        if weapon._charmDot then weapon._charmDot.Visible = true end
        if weapon.CharmCallback then
            pcall(function() weapon.CharmCallback(weapon.Name, itemName) end)
        end
    end

    self:_refreshWeaponCell(weapon)
    self:_renderCosmetics()
end

-- ============================================
-- APPLY TO ALL
-- ============================================
function BroomHackUI:_applyToAll()
    if not self.selectedWeapon then return end
    local wName = self.selectedWeapon.Name

    if self.activeTab == "skin" then
        local skinName = self.equippedSkins[wName]
        if not skinName then return end
        for _, w in ipairs(self.weapons) do
            -- Check if this weapon has a skin with that name
            for _, sk in ipairs(w.Skins or {}) do
                if sk.Name == skinName then
                    self.equippedSkins[w.Name] = skinName
                    if w._skinDot then w._skinDot.Visible = true end
                    if sk.Callback then
                        pcall(function() sk.Callback(w.Name, skinName) end)
                    end
                    break
                end
            end
            self:_refreshWeaponCell(w)
        end

    elseif self.activeTab == "wrap" then
        local wrapName = self.equippedWraps[wName]
        if not wrapName then return end
        for _, w in ipairs(self.weapons) do
            self.equippedWraps[w.Name] = wrapName
            if w._wrapDot then w._wrapDot.Visible = true end
            if w.WrapCallback then
                pcall(function() w.WrapCallback(w.Name, wrapName) end)
            end
            self:_refreshWeaponCell(w)
        end

    elseif self.activeTab == "charm" then
        local charmName = self.equippedCharms[wName]
        if not charmName then return end
        for _, w in ipairs(self.weapons) do
            self.equippedCharms[w.Name] = charmName
            if w._charmDot then w._charmDot.Visible = true end
            if w.CharmCallback then
                pcall(function() w.CharmCallback(w.Name, charmName) end)
            end
            self:_refreshWeaponCell(w)
        end
    end
end

-- ============================================
-- PUBLIC API
-- ============================================
function BroomHackUI:SetKeybind(keyCode)
    self.keybindLabel.Text = "[" .. keyCode.Name .. "]"
    UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.KeyCode == keyCode then
            self.mainFrame.Visible = not self.mainFrame.Visible
        end
    end)
end

function BroomHackUI:SetEquipped(weaponName, skinName)
    self.equippedSkins[weaponName] = skinName
    local w = self._weaponsByName[weaponName]
    if w then self:_refreshWeaponCell(w) end
end

function BroomHackUI:SetEquippedWrap(weaponName, wrapName)
    self.equippedWraps[weaponName] = wrapName
    local w = self._weaponsByName[weaponName]
    if w then self:_refreshWeaponCell(w) end
end

function BroomHackUI:Toggle() self.mainFrame.Visible = not self.mainFrame.Visible end
function BroomHackUI:Show()   self.mainFrame.Visible = true  end
function BroomHackUI:Hide()   self.mainFrame.Visible = false end
function BroomHackUI:Destroy()
    if self._spinConnection then
        self._spinConnection:Disconnect()
        self._spinConnection = nil
    end
    self:_clearViewports()
    self.screenGui:Destroy()
end

return BroomHackUI
